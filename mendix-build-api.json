          "callbacks": []
        }
      ],
      "responseMode": null,
      "streamingMode": null,
      "streamingInterval": 0
    },
    {
      "uuid": "b1000003-0000-0000-0000-000000000003",
      "type": "http",
      "documentation": "Retrieve a specific deployment package. Add ?url=true to include a download URL.",
      "method": "get",
      "endpoint": "api/1/apps/:AppId/packages/:PackageId",
      "responses": [
        {
          "uuid": "16db9e24-4108-4554-ba94-6048b4fe3da9",
          "body": "{{{stringify (find (dataRaw 'buildPackages') (object PackageId=(urlParam 'PackageId')))}}}",
          "latency": 0,
          "statusCode": 200,
          "label": "OK - Package info (no URL)",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "bodyType": "INLINE",
          "filePath": "",
          "databucketID": "",
          "sendFileAsBody": false,
          "rules": [
            {
              "target": "query",
              "modifier": "url",
              "operator": "equals",
              "invert": true,
              "value": "true"
            }
          ],
          "rulesOperator": "OR",
          "disableTemplating": false,
          "fallbackTo404": false,
          "default": true,
          "crudKey": "id",
          "callbacks": []
        },
        {
          "uuid": "630330f9-0325-4059-81fe-58102bc963bd",
          "body": "{{setVar 'pkg' (find (dataRaw 'buildPackages') (object PackageId=(urlParam 'PackageId')))}}\n{{#if @pkg}}{{{stringify (object PackageId=(lookup @pkg 'PackageId') Name=(lookup @pkg 'Name') Description=(lookup @pkg 'Description') Version=(lookup @pkg 'Version') Creator=(lookup @pkg 'Creator') CreationDate=(lookup @pkg 'CreationDate') Status=(lookup @pkg 'Status') Size=(lookup @pkg 'Size') Url=(object Location=(concat \"https://cdn.mendix.com/packages/\" (urlParam 'PackageId') \".mda?token=\" (faker 'string.alphanumeric' 32)) TTL=3600))}}}{{else}}{\"errorMessage\":\"PACKAGE_NOT_FOUND\"}{{/if}}",
          "latency": 0,
          "statusCode": 200,
          "label": "OK - Package info with download URL",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
