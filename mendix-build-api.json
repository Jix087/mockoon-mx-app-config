    {
      "uuid": "b1000002-0000-0000-0000-000000000002",
      "type": "http",
      "documentation": "Start building a deployment package from the team server project.",
      "method": "post",
      "endpoint": "api/1/apps/:AppId/packages",
      "responses": [
        {
          "uuid": "49430318-6b5d-4c0b-b255-cc150c51535a",
          "body": "{{setVar 'pid' (faker 'string.uuid')}}\n{{setData 'set' 'buildPackages' @pid (object PackageId=@pid Name=(concat (body 'Branch' 'Main line') '-' (body 'Version' '1.0.0') '.mda') Description=(body 'Description' '') Version=(body 'Version' '1.0.0') Creator='build-service@starfleet.com' CreationDate=(now 'x') Status='Queued' Size=0)}}\n{\"PackageId\":\"{{@pid}}\"}",
          "latency": 0,
          "statusCode": 200,
          "label": "OK - Build started, returns PackageId",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "bodyType": "INLINE",
          "filePath": "",
          "databucketID": "",
          "sendFileAsBody": false,
          "rules": [],
          "rulesOperator": "OR",
          "disableTemplating": false,
          "fallbackTo404": false,
          "default": true,
          "crudKey": "id",
          "callbacks": []
        },
        {
          "uuid": "ea6251e0-86c9-4ee4-8492-8ecd17883a8d",
          "body": "{\"errorMessage\":\"INVALID_PARAMETERS\",\"message\":\"Branch and Version are required\"}",
          "latency": 0,
          "statusCode": 400,
          "label": "Bad Request - Invalid parameters",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "bodyType": "INLINE",
