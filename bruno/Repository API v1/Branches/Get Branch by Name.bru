meta {
  name: Get Branch by Name
  type: http
  seq: 2
}

get {
  url: {{repository_base_url}}/v1/repositories/{{app_id}}/branches/{{branch_name}}
  body: none
  auth: none
}

headers {
  Authorization: MxToken {{mendix_pat}}
  Content-Type: application/json
}

docs {
  Retrieve information about a specific branch.
  The branch name must be URL-encoded (e.g. "feature/my-branch" → "feature%2Fmy-branch").
}
