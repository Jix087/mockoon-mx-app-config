meta {
  name: Get List Runs
  type: http
  seq: 3
}

get {
  url: {{git_base_url}}/repos/{{git_owner}}/{{git_repo}}/actions/runs
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{git_token}}
  Content-Type: application/json
}

docs {
  List all workflow runs tracked in the workflowRuns data bucket.
  Runs are added when POST /dispatches is called.
}
