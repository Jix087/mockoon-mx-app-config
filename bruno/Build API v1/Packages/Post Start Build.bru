meta {
  name: Post Start Build
  type: http
  seq: 1
}

post {
  url: {{build_base_url}}/api/1/apps/{{app_id}}/packages
  body: json
  auth: none
}

headers {
  Mendix-Username: {{mendix_username}}
  Mendix-ApiKey: {{mendix_apikey}}
  Content-Type: application/json
}

body:json {
{
  "Branch": "main",
  "Revision": "HEAD",
  "Version": "2.6.0",
  "Description": "New build from main branch"
}
}

