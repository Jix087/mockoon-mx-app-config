meta {
  name: Get All Packages
  type: http
  seq: 1
}

get {
  url: {{build_base_url}}/api/1/apps/{{app_id}}/packages
  body: none
  auth: none
}

headers {
  Mendix-Username: {{mendix_username}}
  Mendix-ApiKey: {{mendix_apikey}}
  Content-Type: application/json
}

docs {
  Retrieve all deployment packages for the app.
}
