meta {
  name: Get Application Log
  type: http
  seq: 1
}

get {
  url: {{deploy_base_url}}/api/1/apps/{{app_id}}/environments/{{mode}}/logs/2026-03-20
  body: none
  auth: none
}

headers {
  Mendix-Username: {{mendix_username}}
  Mendix-ApiKey: {{mendix_apikey}}
  Content-Type: application/json
}

