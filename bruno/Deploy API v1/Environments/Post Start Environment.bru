meta {
  name: Post Start Environment
  type: http
  seq: 1
}

post {
  url: {{deploy_base_url}}/api/1/apps/{{app_id}}/environments/{{mode}}/start
  body: json
  auth: none
}

headers {
  Mendix-Username: {{mendix_username}}
  Mendix-ApiKey: {{mendix_apikey}}
  Content-Type: application/json
}

body:json {
  {}
}

docs {
  Start the environment. Copy the returned JobId into the job_id variable.
}
